{
  "name": "jumpjump",
  "displayName": "JumpJump",
  "description": "在侧边栏收藏、分组、搜索和跳转仓库里的目录、文件与代码位置。",
  "version": "0.1.3",
  "icon": "media/marketplace-icon.png",
  "publisher": "SivanLiu",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/SivanCola/JumpJump.git"
  },
  "homepage": "https://github.com/SivanCola/JumpJump",
  "bugs": {
    "url": "https://github.com/SivanCola/JumpJump/issues"
  },
  "galleryBanner": {
    "color": "#1f2233",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "files": [
    "out/src/**/*.js",
    "media/**",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "bookmark",
    "navigation",
    "jump",
    "workspace",
    "repository",
    "cursor",
    "vscode",
    "go",
    "python",
    "sidebar",
    "bookmarks",
    "theme"
  ],
  "activationEvents": [
    "onView:jumpjump.bookmarks",
    "onCommand:jumpjump.addCurrentFile",
    "onCommand:jumpjump.addCurrentLine",
    "onCommand:jumpjump.addCurrentFolder",
    "onCommand:jumpjump.addFolder",
    "onCommand:jumpjump.refresh",
    "onCommand:jumpjump.refresh.zh",
    "onCommand:jumpjump.refresh.en",
    "onCommand:jumpjump.deleteBookmark",
    "onCommand:jumpjump.renameBookmark",
    "onCommand:jumpjump.togglePinned",
    "onCommand:jumpjump.openBookmark",
    "onCommand:jumpjump.removeMissing"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "configuration": {
      "title": "JumpJump",
      "properties": {
        "jumpjump.compactMode": {
          "type": "boolean",
          "default": true,
          "description": "使用更紧凑的 JumpJump 侧边栏布局，减少间距并压缩书签行。"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "jumpjump",
          "title": "JumpJump",
          "icon": "media/jumpjump.svg"
        }
      ]
    },
    "views": {
      "jumpjump": [
        {
          "id": "jumpjump.bookmarks",
          "name": "Bookmarks",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "jumpjump.addCurrentFile",
        "title": "JumpJump: Add Current File"
      },
      {
        "command": "jumpjump.addCurrentLine",
        "title": "JumpJump: Add Current Location"
      },
      {
        "command": "jumpjump.addCurrentFolder",
        "title": "JumpJump: Add Current Folder"
      },
      {
        "command": "jumpjump.addFolder",
        "title": "JumpJump: Add Folder"
      },
      {
        "command": "jumpjump.refresh",
        "title": "JumpJump: Refresh"
      },
      {
        "command": "jumpjump.refresh.zh",
        "title": "JumpJump: 刷新"
      },
      {
        "command": "jumpjump.refresh.en",
        "title": "JumpJump: Refresh"
      },
      {
        "command": "jumpjump.deleteBookmark",
        "title": "JumpJump: Delete Bookmark"
      },
      {
        "command": "jumpjump.renameBookmark",
        "title": "JumpJump: Rename Bookmark"
      },
      {
        "command": "jumpjump.togglePinned",
        "title": "JumpJump: Toggle Pin"
      },
      {
        "command": "jumpjump.openBookmark",
        "title": "JumpJump: Open Bookmark"
      },
      {
        "command": "jumpjump.removeMissing",
        "title": "JumpJump: Clean Missing",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "jumpjump.refresh.zh",
          "when": "view == jumpjump.bookmarks && jumpjump.locale == zh",
          "group": "navigation@1"
        },
        {
          "command": "jumpjump.refresh.en",
          "when": "view == jumpjump.bookmarks && jumpjump.locale == en",
          "group": "navigation@1"
        }
      ],
      "editor/title/context": [
        {
          "command": "jumpjump.addCurrentFile",
          "group": "navigation@90"
        },
        {
          "command": "jumpjump.addCurrentFolder",
          "group": "navigation@91"
        }
      ],
      "editor/context": [
        {
          "command": "jumpjump.addCurrentLine",
          "group": "navigation@90"
        },
        {
          "command": "jumpjump.addCurrentFile",
          "group": "navigation@91"
        },
        {
          "command": "jumpjump.addCurrentFolder",
          "group": "navigation@92"
        }
      ],
      "explorer/context": [
        {
          "command": "jumpjump.addCurrentFile",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "navigation@98"
        },
        {
          "command": "jumpjump.addCurrentFolder",
          "when": "resourceScheme == file && explorerResourceIsFolder",
          "group": "navigation@98"
        }
      ],
      "commandPalette": [
        {
          "command": "jumpjump.refresh.zh",
          "when": "false"
        },
        {
          "command": "jumpjump.refresh.en",
          "when": "false"
        },
        {
          "command": "jumpjump.addFolder",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "build": "node -e \"require('fs').rmSync('out',{ recursive: true, force: true })\" && tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit -p ./",
    "test": "mocha --require ts-node/register test/**/*.test.ts",
    "vscode:prepublish": "npm run build",
    "package:vsix": "node -e \"require('fs').mkdirSync('dist',{ recursive: true })\" && vsce package --out dist/jumpjump.vsix"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.90.0",
    "mocha": "^11.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  },
  "overrides": {
    "diff": "^9.0.0",
    "serialize-javascript": "^7.0.5"
  }
}
